# Workspace behaviour
link-workspace-packages=true
prefer-workspace-packages=true

# Security — keep strict isolation (pnpm default, made explicit)
shamefully-hoist=false

# Avoid install failures from peer dep warnings during early scaffolding
strict-peer-dependencies=false

# Always save exact versions
save-exact=true

# Allow esbuild (vitest dependency) to run its install script
package-manager-strict=false
