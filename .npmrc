# Workspace behaviour
link-workspace-packages=true
prefer-workspace-packages=true

# Keep strict pnpm dependency isolation
shamefully-hoist=false

# Avoid installation failures from peer dependency warnings during initial scaffolding
strict-peer-dependencies=false

# Save dependency versions exactly
save-exact=true

# Allow esbuild (vitest dependency) to run its install script
package-manager-strict=false

# Reject unsupported Node.js and package-manager runtimes
engine-strict=true

# Network resilience — retry slow/dropped downloads
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000
