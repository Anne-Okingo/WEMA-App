# =============================================================================
# WEMA Backend — Environment Configuration
#
# Copy this file to .env and fill in real values for local development.
# Never commit .env or any file containing real secrets.
#
# To validate your configuration:
#   pnpm --filter @wema/api dev
# The application will print a clear error and exit if any required value is
# missing or invalid before it accepts any requests.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Application environment.
# Allowed: development | test | staging | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------

# Port the HTTP server listens on.
API_PORT=3001

# Host port mappings for Docker Compose (override if defaults conflict).
# The API container always listens internally on 3000.
HOST_API_PORT=3001
PATIENT_APP_PORT=5173
PSYCHOLOGIST_PORTAL_PORT=5174

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Local development (non-Docker): point to your local Postgres instance.
# Docker Compose: the api service overrides this with the postgres service URL;
#   you do not need to change this value when using docker compose up.
DATABASE_URL=postgresql://wema:wema@localhost:5434/wema_dev

# Separate database used by the test suite.
# Must point to a different database from DATABASE_URL to avoid data loss.
DATABASE_TEST_URL=postgresql://wema:wema@localhost:5434/wema_test

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Minimum log level emitted.
# Allowed: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------

# Secret used to sign JWT access tokens.
# Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=<replace-with-a-random-secret-at-least-32-chars>

# Lifetime of a JWT access token (ms / zeit/ms format).
JWT_EXPIRES_IN=15m

# -----------------------------------------------------------------------------
# Background jobs
# -----------------------------------------------------------------------------

# PostgreSQL schema used by the job queue (pg-boss).
JOB_QUEUE_SCHEMA=wema_jobs

# -----------------------------------------------------------------------------
# Wonder HMIS integration
# -----------------------------------------------------------------------------

# Set to true only when actively developing or testing the Wonder integration.
# When false, WONDER_BASE_URL / WONDER_CLIENT_ID / WONDER_CLIENT_SECRET are
# not required and the integration adapter will not be initialised.
WONDER_ENABLED=false

# Base URL of the Wonder HMIS API (required when WONDER_ENABLED=true).
WONDER_BASE_URL=https://wonder.example.com/api

# OAuth2 client credentials issued by Wonder (required when WONDER_ENABLED=true).
WONDER_CLIENT_ID=<wonder-client-id>
WONDER_CLIENT_SECRET=<wonder-client-secret>

# -----------------------------------------------------------------------------
# WhatsApp notification integration
# -----------------------------------------------------------------------------

# Set to true only when actively developing or testing WhatsApp alerts.
# When false, WHATSAPP_API_URL / WHATSAPP_ACCESS_TOKEN / WHATSAPP_DESTINATION
# are not required and the notification adapter will not be initialised.
WHATSAPP_ENABLED=false

# WhatsApp Business API base URL (required when WHATSAPP_ENABLED=true).
WHATSAPP_API_URL=https://graph.facebook.com/v19.0

# Access token for the WhatsApp Business API (required when WHATSAPP_ENABLED=true).
WHATSAPP_ACCESS_TOKEN=<whatsapp-access-token>

# Destination group ID or phone number for high-risk alerts
# (required when WHATSAPP_ENABLED=true).
WHATSAPP_DESTINATION=<whatsapp-group-id-or-phone>
