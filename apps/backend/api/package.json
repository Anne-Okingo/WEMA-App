{
  "name": "@wema/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/app/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@wema/database": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.3.0",
    "pino": "^10.3.1",
    "pino-http": "^10.5.0",
    "uuid": "^14.0.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.1.0",
    "tsx": "^4.20.3",
    "typescript": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
