{
  "name": "wema",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "description": "WEMA — an offline-first mental health screening and care-routing platform.",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:frontend": "pnpm --filter \"./apps/frontend/*\" run test",
    "backend:lint": "eslint 'apps/backend/**/*.ts' 'packages/**/*.ts'",
    "backend:format:check": "prettier --check 'apps/backend/**/*.ts' 'packages/**/*.ts'",
    "backend:format:write": "prettier --write 'apps/backend/**/*.ts' 'packages/**/*.ts'",
    "backend:typecheck": "pnpm --filter @wema/api --filter @wema/worker --filter @wema/database run typecheck",
    "backend:test": "pnpm --filter @wema/api --filter @wema/worker --filter @wema/database run test",
    "backend:test:coverage": "pnpm --filter @wema/api --filter @wema/worker run test -- --coverage",
    "backend:build": "pnpm --filter @wema/database --filter @wema/api --filter @wema/worker run build",
    "lint": "pnpm --filter \"./apps/frontend/*\" run lint",
    "typecheck": "pnpm --filter \"./apps/frontend/*\" run typecheck",
    "format:check": "pnpm --filter \"./apps/frontend/*\" run format:check",
    "format:write": "pnpm --filter \"./apps/frontend/*\" run format:write",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "typescript": "5.9.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": "11.15.1"
  }
}
