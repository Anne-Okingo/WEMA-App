{
  "name": "wema-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "WEMA is an offline-first maternal mental health screening app for hospital waiting rooms. Patients complete an EPDS assessment on a tablet, get instant results, and are automatically routed to care.",
  "workspaces": [
    "apps/frontend/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint apps/frontend --ext .ts,.tsx",
    "format:check": "prettier --check apps/frontend",
    "format:write": "prettier --write apps/frontend",
    "typecheck": "tsc --noEmit -p apps/frontend/patient-app/tsconfig.json -p apps/frontend/psychologist-portal/tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "typescript": "~5.6.2",
    "vitest": "^2.1.8"
  }
}
